<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/auth_nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.precisionlayertesting.features.auth.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        
        <action
            android:id="@+id/action_splashFragment_to_getStartedFragment"
            app:destination="@id/getStartedFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
            
        <action
            android:id="@+id/action_splashFragment_to_chooseWorkspaceTypeFragment"
            app:destination="@id/chooseWorkspaceTypeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
            
    </fragment>

    <fragment
        android:id="@+id/getStartedFragment"
        android:name="com.example.precisionlayertesting.features.auth.GetStartedFragment"
        android:label="GetStarted"
        tools:layout="@layout/fragment_get_started"
        >

        <action
            android:id="@+id/action_getStarted_to_login"
            app:destination="@id/loginFragment"
            />

    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.precisionlayertesting.features.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login" >

        <argument
            android:name="isFromIndividual"
            app:argType="boolean"
            android:defaultValue="false" />

        <argument
            android:name="isInvited"
            app:argType="boolean"
            android:defaultValue="false" />

        <action
            android:id="@+id/action_loginFragment_to_chooseWorkspaceTypeFragment"
            app:destination="@id/chooseWorkspaceTypeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"
             />

        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment" />

    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.precisionlayertesting.features.auth.SignupFragment"
        android:label="Signup"
        tools:layout="@layout/fragment_signup">
        
        <action
            android:id="@+id/action_signupFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_signupFragment_to_chooseWorkspaceTypeFragment"
            app:destination="@id/chooseWorkspaceTypeFragment"
            app:popUpTo="@id/signupFragment"
            app:popUpToInclusive="true" />
            
    </fragment>

    <fragment
        android:id="@+id/chooseWorkspaceTypeFragment"
        android:name="com.example.precisionlayertesting.features.auth.ChooseWorkspaceTypeFragment"
        android:label="Choose Workspace Type"
        tools:layout="@layout/fragment_choose_workspace_type">

        <argument
            android:name="userId"
            app:argType="string" />

        <action
            android:id="@+id/action_chooseWorkspaceTypeFragment_to_createWorkspaceFragment"
            app:destination="@id/createWorkspaceFragment" />

        <action
            android:id="@+id/action_chooseWorkspaceTypeFragment_to_joinWorkspaceFragment"
            app:destination="@id/joinWorkspaceFragment" />

    </fragment>

    <fragment
        android:id="@+id/createWorkspaceFragment"
        android:name="com.example.precisionlayertesting.features.auth.CreateWorkspaceFragment"
        android:label="Create Workspace"
        tools:layout="@layout/fragment_create_workspace">
        
        <argument
            android:name="userId"
            app:argType="string" />
            
    </fragment>

    <fragment
        android:id="@+id/joinWorkspaceFragment"
        android:name="com.example.precisionlayertesting.features.auth.JoinWorkspaceFragment"
        android:label="Join Workspace"
        tools:layout="@layout/fragment_join_workspace">
        
        <argument
            android:name="userId"
            app:argType="string" />

        <action
            android:id="@+id/action_joinWorkspaceFragment_to_createWorkspaceFragment"
            app:destination="@id/createWorkspaceFragment" />
            
    </fragment>

</navigation>
