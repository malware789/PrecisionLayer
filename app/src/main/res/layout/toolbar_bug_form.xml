<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <!-- Top row: title + badge + Add Bug button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        >

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="3dp"
            android:elevation="5dp"
            android:layout_marginEnd="15dp"
            >

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:src="@drawable/arrowback"
                android:layout_gravity="center" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Left: label + title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report Bugs"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B3FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="2dp" />


        </LinearLayout>

        <!-- Bug count badge -->
        <TextView
            android:id="@+id/tvBugCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_pill_white"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="0 Bugs"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            android:visibility="visible" />

        <!-- Add Bug button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddAnotherBug"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Add Bug"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            app:strokeColor="#66FFFFFF"
            app:cornerRadius="18dp"
            android:backgroundTint="#33FFFFFF" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>