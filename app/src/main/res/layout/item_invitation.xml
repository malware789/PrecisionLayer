<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/surface_container_lowest"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="#1A737784"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ivWorkspaceIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="#F1F5F9"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvWorkspaceInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#64748B"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="W" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvWorkspaceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivWorkspaceIcon"
            app:layout_constraintTop_toTopOf="@id/ivWorkspaceIcon"
            tools:text="Acme Corp Team" />

        <TextView
            android:id="@+id/tvRoleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_badge_pill"
            android:backgroundTint="#EFF6FF"
            android:paddingHorizontal="10dp"
            android:paddingVertical="2dp"
            android:textColor="#2563EB"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvWorkspaceName"
            app:layout_constraintTop_toBottomOf="@id/tvWorkspaceName"
            tools:text="TESTER" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivWorkspaceIcon">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Decline"
                android:textColor="#64748B"
                app:cornerRadius="12dp"
                app:strokeColor="#E2E8F0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Accept"
                android:textColor="#FFFFFF"
                app:backgroundTint="#0F172A"
                app:cornerRadius="12dp"
                app:elevation="0dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
