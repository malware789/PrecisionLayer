<?xml version="1.0" encoding="utf-8"?>
<!--
    Get Started Options — matches Stitch screen (project 14320903288817197372)

    Layout:
      ┌─────────────────────────────────┐
      │  Logo icon + "PrecisionLayer"   │  ← top-left header
      │                                 │
      │  Choose your workspace type     │  ← bold headline
      │  Select the environment that…   │  ← subtitle 14sp muted
      │                                 │
      │  ┌───────────────────────────┐  │
      │  │ [🏢] Organization         │  │  ← white card, 20dp radius
      │  │ For collaborative teams…  │  │
      │  │ [SSO ENABLED][UNLIMITED…] │  │  ← badge pills
      │  │ [Continue with Org ────]  │  │  ← filled navy button
      │  └───────────────────────────┘  │
      │                                 │
      │  ┌───────────────────────────┐  │
      │  │ [👤] Individual           │  │  ← white card, 20dp radius
      │  │ For personal testing…     │  │
      │  │ [CLOUD SANDBOX][SOLO DEV] │  │  ← badge pills
      │  │ [Continue as Individual─] │  │  ← outlined button
      │  └───────────────────────────┘  │
      │                                 │
      │  SECURE BY DESIGN • PRECISION…  │  ← footer text centered
      └─────────────────────────────────┘
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    >

    <LinearLayout
        android:id="@+id/llfirst"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"

        >
        <!-- ===== BRAND HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            >
            <!-- Logo icon chip -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#002171">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="P"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="PrecisionLayer"
                android:textColor="#002171"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>


        <!-- ===== MAIN HEADING ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your workspace type"
            android:textColor="#0D1B2A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="15dp"
            />

        <!-- ===== SUBTITLE ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Select the environment that best fits your testing workflow and architectural needs."
            android:textColor="#5F6368"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#F8F9FE"
        android:overScrollMode="never"
        android:fillViewport="false"
        android:fitsSystemWindows="true"
        app:layout_constraintTop_toBottomOf="@+id/llfirst"
        app:layout_constraintBottom_toTopOf="@+id/versionFooter"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="36dp">

            <!-- ===== ORGANIZATION CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Icon chip row -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#E3F2FD">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_compass"
                            android:contentDescription="Organization"
                            app:tint="#002171" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Organization"
                        android:textColor="#0D1B2A"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- Description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="For collaborative teams and enterprise projects. Unified billing, role-based access control, and shared test suites."
                        android:textColor="#757575"
                        android:textSize="14sp"
                        android:lineSpacingExtra="3dp" />

                    <!-- Badge pills row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_pill"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="SSO ENABLED"
                            android:textColor="#002171"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_badge_pill"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="UNLIMITED SEATS"
                            android:textColor="#002171"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                    <!-- Continue with Org — filled navy button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOrganization"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="15dp"
                        android:text="Continue with Organization"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="#002171"
                        app:cornerRadius="10dp"
                        app:elevation="0dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== INDIVIDUAL CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="10dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Icon chip row -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#E3F2FD">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:contentDescription="Individual"
                            app:tint="#002171" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Individual"
                        android:textColor="#0D1B2A"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- Description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="For personal testing and small independent projects. Quick setup and core PrecisionLayer features at no initial cost."
                        android:textColor="#757575"
                        android:textSize="14sp"
                        android:lineSpacingExtra="3dp" />

                    <!-- Badge pills row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_pill"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="CLOUD SANDBOX"
                            android:textColor="#002171"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_badge_pill"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="SOLO DEV"
                            android:textColor="#002171"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                    </LinearLayout>

                    <!-- Continue as Individual — outlined ghost button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnIndividual"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="15dp"
                        android:text="Continue as Individual"
                        android:textColor="#002171"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/lightestGrey"
                        app:cornerRadius="10dp"
                        app:strokeColor="#C3C6D5"
                        app:strokeWidth="1dp"
                        app:elevation="0dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>


    <!-- ===== FOOTER ===== -->
    <TextView
        android:id="@+id/versionFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:letterSpacing="0.05"
        android:text="SECURE BY DESIGN  •  PRECISION LAYER ARCHITECTURE v4.2"
        android:textAllCaps="true"
        android:textColor="#909090"
        android:textSize="11sp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>

