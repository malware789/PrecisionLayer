<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="50dp">

            <!-- Summary Section: Added Bugs -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAddedBugs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:layout_marginBottom="10dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_added_bug"

                />


<!--            <TextView-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="ACTIVE BUG ENTRY"-->
<!--                android:textColor="@color/on_surface_variant"-->
<!--                android:textSize="10sp"-->
<!--                android:textStyle="bold"-->
<!--                android:letterSpacing="0.1"-->
<!--                android:layout_marginBottom="10dp" />-->

            <!-- Bug Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bug Title"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:hintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Briefly describe the issue..."
                    android:textSize="14sp"
                    android:padding="16dp"
                    android:background="@drawable/bg_outline_ghost" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Module Dropdown -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Module/Component"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:hintEnabled="false">
                <AutoCompleteTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Authentication Engine"
                    android:inputType="none"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Priority Toggle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Priority"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/togglePriority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:singleSelection="true"
                app:checkedButton="@+id/btnHigh">
                <Button
                    android:id="@+id/btnLow"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LOW"
                    android:textSize="10sp" />
                <Button
                    android:id="@+id/btnMed"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MED"
                    android:textSize="10sp" />
                <Button
                    android:id="@+id/btnHigh"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="HIGH"
                    android:textSize="10sp" />
                <Button
                    android:id="@+id/btnCrit"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CRIT"
                    android:textSize="10sp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                app:hintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="4"
                    android:gravity="top"
                    android:hint="Provide a detailed overview of the unexpected behavior..."
                    android:textSize="14sp"
                    android:padding="16dp"
                    android:background="@drawable/bg_outline_ghost" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Steps Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Steps to Reproduce"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <LinearLayout
                android:id="@+id/llStepsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- Step 1 example -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:text="1."
                        android:textColor="@color/primary"
                        android:textStyle="bold" />
                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Navigate to Login screen"
                        android:background="@null"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add Step"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:layout_marginBottom="15dp" />

            <!-- Attachment Area -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screenshots &amp; Evidence"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_schedule"
                    app:tint="@color/outline" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="ATTACH FILES"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="+ Add Another Bug"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:backgroundTint="@color/primary_fixed_dim2"
                />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom"
        android:paddingHorizontal="24dp"
        android:background="@color/surface">

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textAllCaps="false"
            app:cornerRadius="16dp"
            android:backgroundTint="@color/primary_fixed_dim2"
            />

        <Space
            android:layout_width="16dp"
            android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Submit Bugs"
            android:textAllCaps="false"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/primary" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
