<?xml version="1.0" encoding="utf-8"?>
<!-- item_added_bug.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="2dp"
    android:layout_marginBottom="2dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Top row: severity badge + action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <!-- Severity badge -->
            <TextView
                android:id="@+id/tvSeverityBadge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_badge_pill"
                android:backgroundTint="@color/primary_fixed_dim2"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="HIGH"
                android:textColor="@color/primary"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                tools:ignore="SmallSp"
                android:gravity="center"
                xmlns:tools="http://schemas.android.com/tools" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                />

            <!-- Edit button -->
            <ImageView
                android:id="@+id/ivEdit"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_cloud_upload"
                android:padding="3dp"
                android:background="@drawable/bg_icon_btn_primary"
                app:tint="@color/primary"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp"
                android:contentDescription="Edit bug" />

            <!-- Delete button -->
            <ImageView
                android:id="@+id/ivDelete"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_schedule"
                android:padding="3dp"
                android:background="@drawable/bg_icon_btn_red"
                app:tint="#EB5757"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Delete bug" />

        </LinearLayout>

        <!-- Bug title -->
        <TextView
            android:id="@+id/tvBugTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Untitled Bug"
            android:textColor="@color/on_surface"
            android:textSize="12sp"
            android:textStyle="bold"
            android:minLines="2"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="3dp" />

        <!-- Module name -->
        <TextView
            android:id="@+id/tvModuleName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/on_surface_variant"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</androidx.cardview.widget.CardView>


